{
  "manifest_version": 3,
  "name": "Onichan Bypasser",
  "short_name": "Onichan",
  "version": "2.1.0",
  "description": "💗 Onichan Bypasser — Stripe/Adyen/Checkout/Recurly/Xsolla automation, captcha bypass, card tools, proxy management. Powered by @Onichanbabybot.",
  "author": "Onichan",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Onichan Bypasser"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "webNavigation",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "proxy",
    "notifications",
    "alarms",
    "downloads"
  ],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["https://api.stripe.com/*", "https://js.stripe.com/*", "https://*.stripe.com/*", "<all_urls>"],
      "js": ["jeffrey-inject.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": [
        "*://checkout.stripe.com/*",
        "*://pay.stripe.com/*",
        "*://buy.stripe.com/*",
        "*://donate.stripe.com/*"
      ],
      "js": ["stripe-overlay.js"],
      "css": ["stripe-overlay.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["images/*", "icons/*", "jeffrey-inject.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "minimum_chrome_version": "108"
}
